# Supabase — Project Settings → API (https://supabase.com/dashboard)
# Project URL:
SUPABASE_URL=
# Publishable key (anon / public — safe for browser, not used by this app yet):
SUPABASE_ANON_KEY=
# Secret key (service_role — server only, NEVER expose to client or commit):
SUPABASE_SERVICE_ROLE_KEY=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Be My Dev <hello@bemydev.co.za>
RESEND_TO_EMAIL=you@bemydev.co.za

# Meta WhatsApp Cloud API — https://developers.facebook.com/apps
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_RECIPIENT_NUMBER=27839630497
